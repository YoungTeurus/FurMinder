BOT_TOKEN=your_telegram_bot_token_from_botfather

# Yandex Cloud Managed MongoDB (рекомендуется: пароль отдельно, URI собирается с quote_plus)
MONGODB_USER=botUser
MONGODB_PASSWORD=your_password_here
MONGODB_HOSTS=rc1a-fm21l2iimejg94vo.mdb.yandexcloud.net:27018
MONGODB_REPLICA_SET=rs01
MONGODB_AUTH_SOURCE=furminder
MONGODB_DB=furminder
# Сертификат: скачайте root.crt из консоли Yandex Cloud
# Windows: %USERPROFILE%\.mongodb\root.crt
# Linux/macOS: ~/.mongodb/root.crt
MONGODB_TLS_CA_FILE=%USERPROFILE%\.mongodb\root.crt

# Telegram (для VM в Yandex Cloud, если api.telegram.org недоступен напрямую)
# SOCKS5-прокси с поддержкой Bot API, например TG-CF-proxy: socks5://127.0.0.1:1080
# tg-ws-proxy — MTProto для Telegram Desktop, для Bot API не подходит
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
# TELEGRAM_CONNECT_TIMEOUT=30
# TELEGRAM_READ_TIMEOUT=30
# TELEGRAM_WRITE_TIMEOUT=30
# TELEGRAM_POOL_TIMEOUT=10
